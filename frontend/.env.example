# Copy to frontend/.env

VITE_BACKEND_URL=http://localhost:4000

# Set to true to show the dev-login picker on the login screen.
VITE_ALLOW_DEV_LOGIN=true

# Set to true to enable custodial blockchain auth (OTP + challenge).
VITE_AUTH_BLOCKCHAIN_ENABLED=true

# Optional — only needed for the production Thirdweb wallet login flow.
# VITE_THIRDWEB_CLIENT_ID=
