# Server
PORT=4000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/waternet

# JWT (backend-issued)
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Thirdweb (frontend will use client id; backend verifies tokens)
# Optional: sent as x-client-id header when verifying token
THIRDWEB_CLIENT_ID=

# Optional: override Thirdweb API base URL
THIRDWEB_API_BASE=https://api.thirdweb.com

# CORS
# For local dev you can leave this empty to allow all origins.
# For production, set to your deployed frontend origin(s), comma-separated.
# Example: CORS_ORIGINS=https://waternet.example.com,https://admin.waternet.example.com
CORS_ORIGINS=
