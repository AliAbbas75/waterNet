# Copy to backend/.env

# Mongo connection — single-node replica set so Mongoose transactions work.
MONGODB_URI=mongodb://localhost:27017/waternet?replicaSet=rs0&directConnection=true

# JWT secret for backend-issued auth tokens.
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# HTTP server.
PORT=4000
CORS_ORIGINS=http://localhost:5173

# Auth.
NODE_ENV=development
ALLOW_DEV_LOGIN=true
AUTH_BLOCKCHAIN_ENABLED=true

# OTP provider (Resend)
RESEND_API_KEY=
RESEND_FROM=

# Blockchain auth (required when AUTH_BLOCKCHAIN_ENABLED=true)
AUTH_MASTER_KEY=
CHAIN_RPC_URL=http://127.0.0.1:8545
CHAIN_USER_REGISTRY_ADDRESS=
CHAIN_ADMIN_PRIVATE_KEY=
# Optional: assign SUPER_ADMIN to a specific address on deploy.
# CHAIN_SUPER_ADMIN=

# Thirdweb (optional in dev; required only if exercising the production login flow).
# THIRDWEB_CLIENT_ID=
# THIRDWEB_API_BASE=https://api.thirdweb.com

# MQTT — leave disabled for fully offline dev.
DISABLE_MQTT=true
# MQTT_BROKER_URL=mqtt://localhost:1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
