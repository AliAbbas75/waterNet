{
  "expo": {
    "name": "WaterNet",
    "slug": "waternet",
    "scheme": "waternet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e7490"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "local.waternet.mobile"
    },
    "android": {
      "package": "local.waternet.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e7490"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
